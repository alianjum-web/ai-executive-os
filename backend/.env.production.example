# =============================================================================
# PRODUCTION — copy to: backend/.env on the server (never commit real .env)
# =============================================================================
#   cp .env.production.example .env
# Use strong secrets; APP_ENV=production enables startup validation
# =============================================================================

APP_ENV=production

DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:5432/sop_automator
REDIS_URL=redis://HOST:6379/0

ENCRYPTION_KEY=

# AI — set one provider to match config/features.json "ai_provider"
LLM_PROVIDER=openai
OPENAI_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
ANTHROPIC_API_KEY=
COHERE_API_KEY=

CORS_ORIGINS=https://your-frontend-domain.com
UPLOAD_DIR=/tmp/uploads
DEFAULT_ORG_ID=

SUPABASE_JWT_SECRET=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=documents

SLACK_SIGNING_SECRET=
SLACK_BOT_TOKEN=

SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
