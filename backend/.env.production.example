# Production template — copy to .env.production (gitignored), then copy to .env for local prod test.
# See docs/DEV_VS_PRODUCTION.md

APP_ENV=production

# Hosted Postgres (Supabase pooler, Neon, etc.) OR local Docker for laptop prod test:
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@127.0.0.1:5433/sop_automator
DATABASE_URL=postgresql+asyncpg://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres

# Hosted Redis (Upstash) or local:
# REDIS_URL=redis://127.0.0.1:6379/0
REDIS_URL=rediss://default:YOUR_TOKEN@YOUR.upstash.io:6379

CORS_ORIGINS=https://your-frontend-domain.com
# Local prod UI test only:
# CORS_ORIGINS=http://localhost:3000

ENCRYPTION_KEY=

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=documents

LLM_PROVIDER=gemini
GEMINI_API_KEY=

# Optional
OPENAI_API_KEY=
COHERE_API_KEY=
SENTRY_DSN=
SLACK_SIGNING_SECRET=
SLACK_BOT_TOKEN=
DEFAULT_ORG_ID=
