# Copy to .env.dev and fill in values. See docs/ENV_QUICK_START.md

# Docker Compose maps Postgres to host port 5433 (see docker/docker-compose.yml)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@127.0.0.1:5433/sop_automator
# Use 127.0.0.1:6379 if Redis already runs locally, or redis://127.0.0.1:6380/0 after npm run deps:docker:all
REDIS_URL=redis://127.0.0.1:6379/0
APP_ENV=development
CORS_ORIGINS=http://localhost:3000
ENCRYPTION_KEY=

# Supabase (production auth uses JWKS — no manual JWT secret required)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=documents
# Optional legacy fallback only if your project still issues HS256 user JWTs:
# SUPABASE_JWT_SECRET=

GEMINI_API_KEY=
