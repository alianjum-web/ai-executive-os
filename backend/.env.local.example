# =============================================================================
# LOCAL DEVELOPMENT — copy to: backend/.env
# =============================================================================
#   cp .env.local.example .env
# Then fill GEMINI_API_KEY (or key for ai_provider in config/features.json)
# =============================================================================

APP_ENV=development

# --- Database & cache (localhost; start postgres + redis first) ---
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/sop_automator
REDIS_URL=redis://localhost:6379/0

# --- Security ---
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# --- AI provider (must match "ai_provider" in config/features.json) ---
LLM_PROVIDER=gemini
GEMINI_API_KEY=
GROQ_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
COHERE_API_KEY=

# --- App ---
CORS_ORIGINS=http://localhost:3000
UPLOAD_DIR=/tmp/uploads
DEFAULT_ORG_ID=

# --- Supabase (optional for API JWT verify) ---
SUPABASE_JWT_SECRET=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=documents

# --- Integrations (optional) ---
SLACK_SIGNING_SECRET=
SLACK_BOT_TOKEN=

# --- Observability (optional) ---
SENTRY_DSN=

# --- Feature overrides (optional; defaults in config/features.json) ---
# FEATURE_DOCUMENT_UPLOAD_ENABLED=true
# FEATURE_KNOWLEDGE_AGENT_ENABLED=true
