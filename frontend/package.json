{
  "name": "internal-sop-automator-frontend",
  "version": "0.1.0",
  "private": true,
  "description": "dev → .env.dev. prod → .env.production.",
"scripts": {
    "dev": "bash -c 'set -a && source .env.dev && set +a && exec next dev'",
    "dev:prod": "bash -c 'set -a && source .env.production && set +a && exec next dev'",
    "build": "next build",
    "build:local-dev": "bash -c 'set -a && source .env.dev && set +a && exec next build'",
    "build:local-prod": "bash -c 'set -a && source .env.production && set +a && exec next build'",
    "start": "next start",
    "start:local-dev": "bash -c 'set -a && source .env.dev && set +a && exec next start'",
    "start:local-prod": "bash -c 'set -a && source .env.production && set +a && exec next start'",
    "typecheck": "tsc --noEmit",
    "lint": "eslint",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@reduxjs/toolkit": "^2.5.0",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.49.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.17.0",
    "next": "16.2.9",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-hook-form": "^7.77.0",
    "react-redux": "^9.2.0",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.2.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "tailwindcss": "^4",
    "typescript": "^6"
  }
}
