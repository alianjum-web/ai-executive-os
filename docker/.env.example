# =============================================================================
# AI Executive OS — copy to docker/.env (see docs/ENVIRONMENT_VARIABLES.md)
# =============================================================================

# --- Core (required) ---
OPENAI_API_KEY=sk-your-key
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/sop_automator
REDIS_URL=redis://redis:6379/0
ENCRYPTION_KEY=change-me-generate-with-cryptography-fernet

# --- Supabase Auth (frontend + optional API JWT verify) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_JWT_SECRET=

# --- Supabase Storage (optional; else local UPLOAD_DIR) ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=documents

# --- API / app ---
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
CORS_ORIGINS=http://localhost:3000
APP_ENV=development
DEFAULT_ORG_ID=

# --- RAG (Sprint 2) ---
COHERE_API_KEY=
OPENAI_GRADING_MODEL=gpt-4o-mini
EMBEDDING_BATCH_SIZE=100

# --- LLM provider (Sprint 5) ---
LLM_PROVIDER=openai
ANTHROPIC_API_KEY=

# --- Slack (Sprint 3) ---
SLACK_SIGNING_SECRET=
SLACK_BOT_TOKEN=

# --- Observability (Sprint 5) ---
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# --- Feature flags ---
FEATURE_KNOWLEDGE_AGENT_ENABLED=true
FEATURE_DOCUMENT_UPLOAD_ENABLED=true
FEATURE_MULTI_TENANT_ENABLED=true
FEATURE_ANALYTICS_DASHBOARD_ENABLED=true
FEATURE_PROJECT_AGENT_ENABLED=true
FEATURE_SLACK_WEBHOOK_ENABLED=true
FEATURE_JIRA_INTEGRATION_ENABLED=true
FEATURE_EMAIL_WEBHOOK_ENABLED=true
FEATURE_WORKLOAD_BALANCING_ENABLED=true
FEATURE_AUDIT_LOG_ENABLED=true
FEATURE_RAG_CACHE_ENABLED=true
FEATURE_CUSTOM_LLM_PROVIDER_ENABLED=true

# --- Production compose only ---
POSTGRES_PASSWORD=postgres
